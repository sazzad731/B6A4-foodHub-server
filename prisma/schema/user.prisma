model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  role      Role   @default(CUSTOMER)
  status    Status @default(ACTIVE)
  phone     String?
  address   String?
  image     String?

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  providerProfile ProviderProfile?
  orders          Order[]  @relation("CustomerOrders")
  reviews         Review[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@map("users")
}

enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum Status {
  ACTIVE
  SUSPENDED
}
